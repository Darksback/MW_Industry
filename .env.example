# Database (get from Neon console → Connection Details → Pooled)
DATABASE_URL="postgres://user:password@hostname/dbname?sslmode=require"

# Database Unpooled (for migrations)
DATABASE_URL_UNPOOLED="postgres://user:password@hostname/dbname?sslmode=require"

# NextAuth — AUTH_SECRET is required (run: openssl rand -hex 32)
# NEXTAUTH_URL is NOT needed on Vercel (set automatically)
# For local dev only: NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-hex-32"
NEXTAUTH_SECRET="same-value-as-AUTH_SECRET"
